{% extends "layout.twig" %}

{% block styles %}
<style>
  .section {
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--accent-gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeSlideDown 0.25s ease-out both;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--border-glow), transparent);
  }

  /* ── Tab Navigation ── */
  .tab-nav {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 2rem;
    padding: 0.4rem;
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    animation: fadeSlideDown 0.25s ease-out both;
  }

  .tab-btn {
    flex: 1;
    padding: 0.6rem 1rem;
    background: none;
    border: none;
    border-radius: 10px;
    color: var(--text-secondary);
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .tab-btn:hover {
    color: var(--accent-gold);
    background: rgba(212, 168, 83, 0.08);
  }

  .tab-btn.active {
    background: rgba(212, 168, 83, 0.15);
    color: var(--accent-gold-bright);
  }

  /* ── Charts ── */
  .chart-card {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 1.25rem 1.5rem 1.5rem;
    margin-bottom: 1.5rem;
    animation: fadeSlideUp 0.25s ease-out both;
  }

  .chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .chart-title {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .cup-month-select {
    background: var(--bg-deep);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-secondary);
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .cup-month-select:hover,
  .cup-month-select:focus {
    border-color: var(--border-glow);
    color: var(--accent-gold);
  }

  .cup-month-select option {
    background: #12121c;
    color: var(--text-primary);
  }

  .chart-wrap {
    position: relative;
    height: 220px;
  }

  .chart-wrap.tall {
    height: 280px;
  }

  /* ── Cup History ── */
  .cup-tally {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    animation: fadeSlideUp 0.25s ease-out both;
  }

  .tally-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .tally-count {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 1rem;
  }

  .cup-table th:not(:first-child),
  .cup-table td:not(:first-child) {
    text-align: center;
  }

  .cup-winner-cell {
    font-weight: 600;
  }

  .cup-pts {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .cup-pts.is-winner {
    color: var(--accent-gold-bright);
    font-weight: 600;
  }

  /* ── All-Time House Points ── */
  .house-points-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    animation: fadeSlideUp 0.25s ease-out both;
  }

  .house-pts-card {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 1.5rem 1rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .house-pts-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 50%);
    pointer-events: none;
  }

  .house-pts-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-glow);
    transform: translateY(-4px);
    box-shadow: var(--shadow-ambient), var(--shadow-glow);
  }

  .house-pts-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: 0 0 16px 16px;
  }

  .house-pts-name {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }

  .house-pts-value {
    font-size: 1.4rem;
    font-weight: 700;
    font-family: 'Cinzel', serif;
    color: var(--accent-gold-bright);
  }

  .house-pts-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.15rem;
  }

  /* ── Empty State ── */
  .empty-state {
    text-align: center;
    padding: 3rem 1.5rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    animation: fadeSlideUp 0.25s ease-out both;
  }

  .empty-state-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 0.75rem;
    opacity: 0.5;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .house-points-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .house-pts-card {
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    .cup-tally {
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
    }

    .tab-nav {
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
  }

  @media (max-width: 640px) {
    .house-points-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .house-pts-card {
      padding: 1rem 0.75rem;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(20, 20, 35, 0.95);
    }

    .house-pts-value { font-size: 1.2rem; }

    .cup-tally {
      gap: 0.5rem 1rem;
      font-size: 0.8rem;
    }

    .chart-card {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(20, 20, 35, 0.95);
    }

    .tab-nav {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(20, 20, 35, 0.95);
    }
  }
</style>
{% endblock %}

{% block content %}
<h1>Hall of Fame</h1>

{# ── Tab Navigation ── #}
<div class="tab-nav">
  <button class="tab-btn active" data-tab="house-cup">House Cup</button>
  <button class="tab-btn" data-tab="top-25">Top 25</button>
</div>

{# ── Tab 1: House Cup ── #}
<div class="tab-panel" id="tab-house-cup">

  {# Section 1: House Cup History #}
  <div class="section">
    <div class="section-title">House Cup History</div>

    {% if timeline is empty %}
      <div class="empty-state">
        <span class="empty-state-icon">🏆</span>
        No house cups recorded yet. The first cup will be awarded at the next monthly reset.
      </div>
    {% else %}
      <div class="cup-tally">
        {% for card in cupWinCards %}
        <div class="tally-item">
          <span style="color: {{ card.color }};">{{ card.name }}</span>
          <span class="tally-count" style="color: {{ card.color }};">{{ card.wins }}</span>
        </div>
        {% endfor %}
      </div>

      <div class="chart-card">
        <div class="chart-header">
          <div class="chart-title">House Points</div>
          <select id="cupMonthSelect" class="cup-month-select">
            {% for cup in timeline %}
            <option value="{{ cup.month }}">{{ cup.month }} — {{ cup.winner }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="chart-wrap">
          <canvas id="cupBarChart"></canvas>
        </div>
      </div>

      <div class="table-wrapper">
        <table class="cup-table">
          <thead>
            <tr>
              <th>Month</th>
              <th>Winner</th>
              {% for house in ['Gryffindor', 'Hufflepuff', 'Ravenclaw', 'Slytherin'] %}
              <th style="color: {{ attribute(houseColors, house) }};">{{ house }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for cup in timeline %}
            <tr style="cursor: pointer;" onclick="window.location='/cup/{{ cup.month }}'">
              <td>{{ cup.month }}</td>
              <td class="cup-winner-cell">
                <span style="background: {{ cup.winnerColor }};"></span>
                <span style="color: {{ cup.winnerColor }};">{{ cup.winner }}</span>
              </td>
              {% for entry in cup.houses %}
              <td class="cup-pts {% if entry.isWinner %}is-winner{% endif %}">{{ entry.weightedPoints }}</td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>

  {# Section 2: All-Time House Points #}
  <div class="section">
    <div class="section-title">All-Time House Points</div>

    <div class="house-points-grid">
      {% for house in allTimeHouses %}
      <div class="house-pts-card">
        <div class="house-pts-name" style="color: {{ house.color }};">{{ house.name }}</div>
        <div class="house-pts-value">{{ house.totalPoints | number_format }}</div>
        <div class="house-pts-label">Total Points</div>
        <div class="house-pts-bar" style="background: {{ house.color }};"></div>
      </div>
      {% endfor %}
    </div>
  </div>

</div>

{# ── Tab 2: Top 25 ── #}
<div class="tab-panel" id="tab-top-25" style="display: none;">

  <div class="section">
    <div class="section-title">All-Time Top 25 Students</div>

    {% if students is empty %}
      <div class="empty-state">
        <span class="empty-state-icon">⭐</span>
        No students have earned points yet.
      </div>
    {% else %}
      <div class="chart-card">
        <div class="chart-title">Top 10 by Total Points</div>
        <div class="chart-wrap tall">
          <canvas id="top10Chart"></canvas>
        </div>
      </div>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th>Student</th>
              <th>House</th>
              <th>Total Points</th>
            </tr>
          </thead>
          <tbody>
            {% for student in students %}
            <tr>
              <td class="rank {% if student.rank == 1 %}rank-1{% elseif student.rank == 2 %}rank-2{% elseif student.rank == 3 %}rank-3{% endif %}">#{{ student.rank }}</td>
              <td><a href="/user/{{ student.discordId }}" class="user-link">{{ student.displayName }}</a></td>
              <td style="color: {{ student.houseColor }}; font-weight: 500;">{{ student.house ?: "—" }}</td>
              <td style="color: var(--accent-gold-bright); font-weight: 600;">{{ student.totalPoints }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>

</div>
{% endblock %}

{% block scripts %}
<script>
  Chart.defaults.font.family = "'Outfit', system-ui, sans-serif";
  Chart.defaults.color = 'rgba(240, 230, 211, 0.65)';

  const houseColors = {{ houseColors | json_encode | raw }};
  const chartCupMonths = {{ chartCupMonths | json_encode | raw }};
  const chartTop10 = {{ chartTop10 | json_encode | raw }};

  const gridColor = 'rgba(255, 255, 255, 0.05)';
  const houseOrder = ['Gryffindor', 'Hufflepuff', 'Ravenclaw', 'Slytherin'];

  // ── Cup bar chart ──
  var cupChart = null;

  function getCupChartDatasets(month) {
    var monthData = chartCupMonths.find(function(m) { return m.month === month; });
    if (!monthData) return { data: [], bgColors: [], borderColors: [] };

    var data = [], bgColors = [], borderColors = [];
    houseOrder.forEach(function(house) {
      var entry = monthData.houses.find(function(h) { return h.house === house; });
      var pts = entry ? entry.points : 0;
      var isWinner = entry ? entry.isWinner : false;
      var color = houseColors[house] || '#888888';
      data.push(pts);
      bgColors.push(color + (isWinner ? 'cc' : '55'));
      borderColors.push(color);
    });
    return { data: data, bgColors: bgColors, borderColors: borderColors };
  }

  function initCupChart() {
    var select = document.getElementById('cupMonthSelect');
    if (!select || !chartCupMonths) return;

    var initial = getCupChartDatasets(select.value);
    cupChart = new Chart(document.getElementById('cupBarChart'), {
      type: 'bar',
      data: {
        labels: houseOrder,
        datasets: [{
          data: initial.data,
          backgroundColor: initial.bgColors,
          borderColor: initial.borderColors,
          borderWidth: 2,
          borderRadius: 8,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: { grid: { display: false } },
          y: {
            grid: { color: gridColor },
            beginAtZero: true,
            ticks: { font: { size: 11 } }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) { return ' ' + ctx.parsed.y + ' pts'; }
            }
          }
        }
      }
    });

    select.addEventListener('change', function() {
      var ds = getCupChartDatasets(this.value);
      cupChart.data.datasets[0].data = ds.data;
      cupChart.data.datasets[0].backgroundColor = ds.bgColors;
      cupChart.data.datasets[0].borderColor = ds.borderColors;
      cupChart.update();
    });
  }

  // ── Top 25 tab chart (initialized lazily on first tab open) ──
  var top25Initialized = false;

  function initTop25Charts() {
    if (!chartTop10 || !chartTop10.length) return;
    new Chart(document.getElementById('top10Chart'), {
      type: 'bar',
      data: {
        labels: chartTop10.map(function(s) { return s.label; }),
        datasets: [{
          label: 'Total Points',
          data: chartTop10.map(function(s) { return s.value; }),
          backgroundColor: chartTop10.map(function(s) { return s.color + '99'; }),
          borderColor: chartTop10.map(function(s) { return s.color; }),
          borderWidth: 1.5,
          borderRadius: 6,
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            grid: { color: gridColor },
            beginAtZero: true,
            ticks: { font: { size: 11 } }
          },
          y: {
            grid: { display: false },
            ticks: { font: { size: 12 } }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) { return ' ' + ctx.parsed.x + ' pts'; }
            }
          }
        }
      }
    });
  }

  // ── Tab switching ──
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tabId = btn.dataset.tab;
      document.querySelectorAll('.tab-panel').forEach(function(p) { p.style.display = 'none'; });
      document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
      document.getElementById('tab-' + tabId).style.display = 'block';
      btn.classList.add('active');

      if (tabId === 'top-25' && !top25Initialized) {
        initTop25Charts();
        top25Initialized = true;
      }
    });
  });

  initCupChart();
</script>
{% endblock %}
