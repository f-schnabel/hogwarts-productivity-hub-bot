{
  "name": "hogwarts-productivity-hub-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "analytics:dev": "tsx watch src/analytics-dev.ts",
    "register": "tsx src/register-commands.ts",
    "format": "prettier --write .",
    "test": "vitest",
    "test:arch": "vitest tests/architecture.test.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc",
    "validate": "npm run lint && npm run typecheck"
  },
  "keywords": [
    "discord",
    "bot",
    "productivity",
    "hogwarts",
    "voice-tracking"
  ],
  "author": "Felix Schnabel",
  "license": "ISC",
  "description": "Discord bot for Hogwarts-themed productivity community with voice tracking, house points, and year progression",
  "dependencies": {
    "@vvo/tzdb": "^6.198.0",
    "common-tags": "^1.8.2",
    "dayjs": "^1.11.20",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "twig": "^1.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/common-tags": "^1.8.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/twig": "^1.12.17",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "archunit": "^2.1.63",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "knip": "^5.88.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all"
  }
}
